# TLive Configuration
# Copy to ~/.tlive/config.env and fill in your values
# chmod 600 ~/.tlive/config.env

# Core
TL_PORT=8080
TL_TOKEN=your-token-here
TL_PUBLIC_URL=
# TL_CORE_URL=http://localhost:8080  # Override if Core runs on a different host

# Enabled IM channels (comma-separated: telegram,discord,feishu)
TL_ENABLED_CHANNELS=

# Telegram
TL_TG_BOT_TOKEN=
TL_TG_CHAT_ID=
TL_TG_ALLOWED_USERS=

# Discord
TL_DC_BOT_TOKEN=
TL_DC_ALLOWED_USERS=
TL_DC_ALLOWED_CHANNELS=

# Feishu
TL_FS_APP_ID=
TL_FS_APP_SECRET=
TL_FS_ALLOWED_USERS=

# Runtime: claude (default), codex, auto
TL_RUNTIME=claude
TL_DEFAULT_WORKDIR=
TL_DEFAULT_MODEL=
