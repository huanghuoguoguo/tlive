{
  "name": "tlive",
  "version": "0.1.0",
  "description": "Terminal live monitoring + IM bridge for AI coding tools",
  "type": "module",
  "bin": {
    "tlive": "./scripts/cli.js"
  },
  "files": [
    "scripts/cli.js",
    "scripts/postinstall.js",
    "scripts/hook-handler.sh",
    "scripts/notify-handler.sh",
    "scripts/daemon.sh",
    "scripts/statusline.sh",
    "scripts/doctor.sh",
    "scripts/install.sh",
    "bridge/dist/",
    "bridge/package.json",
    "SKILL.md",
    "config.env.example"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "cd bridge && npm install && npm run build && npm test",
    "build": "cd bridge && npm run build",
    "test": "cd bridge && npm test",
    "test:go": "cd core && go test ./... -v -timeout 30s"
  },
  "keywords": [
    "terminal",
    "monitoring",
    "claude-code",
    "telegram",
    "discord",
    "feishu",
    "ai-coding",
    "remote-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/termlive/termlive"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
