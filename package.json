{
  "name": "tlive",
  "version": "0.11.1",
  "description": "IM bridge for Claude Code — chat from Telegram, Feishu, or QQ Bot",
  "type": "module",
  "main": "dist/main.mjs",
  "bin": {
    "tlive": "./scripts/cli.js"
  },
  "files": [
    "scripts/cli.js",
    "scripts/postinstall.js",
    "scripts/preuninstall.js",
    "scripts/hook-handler.mjs",
    "scripts/notify-handler.mjs",
    "scripts/stop-handler.mjs",
    "scripts/hook-handler.sh",
    "scripts/notify-handler.sh",
    "scripts/stop-handler.sh",
    "scripts/daemon.sh",
    "scripts/statusline.mjs",
    "scripts/statusline.sh",
    "scripts/doctor.sh",
    "scripts/install.sh",
    "dist/",
    "SKILL.md",
    "references/",
    "config.env.example"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "prepublishOnly": "npm run build && npm test",
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src esbuild.config.js",
    "format": "biome format --write src esbuild.config.js",
    "check": "npm run typecheck && npm run lint && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "terminal",
    "monitoring",
    "claude-code",
    "telegram",
    "feishu",
    "ai-coding",
    "remote-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huanghuoguoguo/tlive"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "grammy": "^1.41.1",
    "https-proxy-agent": "^9.0.0",
    "markdown-it": "^14.1.1",
    "socks-proxy-agent": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
