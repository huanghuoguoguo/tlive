{
  "name": "tlive",
  "version": "0.13.2",
  "description": "IM bridge for Claude Code — chat from Telegram, Feishu, or QQ Bot",
  "type": "module",
  "main": "dist/main.mjs",
  "bin": {
    "tlive": "./scripts/cli.js"
  },
  "files": [
    "scripts/cli.js",
    "scripts/postinstall.js",
    "scripts/preuninstall.js",
    "scripts/doctor.sh",
    "dist/",
    "commands/",
    "SKILL.md",
    "references/",
    "config.env.example"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "prepublishOnly": "npm run check && npm run build",
    "build": "node esbuild.config.js",
    "build:watch": "chokidar \"src/**/*.ts\" -c \"node esbuild.config.js\" --initial --throttle 300",
    "dev": "npm run build:watch & TL_DEFAULT_WORKDIR=\"$PWD\" TL_RUNTIME=claude nodemon --config nodemon.json dist/main.mjs",
    "start": "npm run build && TL_DEFAULT_WORKDIR=\"$PWD\" TL_RUNTIME=claude node dist/main.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src esbuild.config.js",
    "lint:dead": "npx knip",
    "lint:entropy": "bash scripts/entropy-check.sh",
    "lint:duplicate": "npx jscpd src --min-lines 5 --min-tokens 40 --ignore \"**/__tests__/**\"",
    "lint:patterns": "bash scripts/lint-patterns.sh",
    "lint:type-coverage": "npx type-coverage",
    "format": "biome format --write src esbuild.config.js",
    "check": "npm run typecheck && npm run lint && npm test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "keywords": [
    "terminal",
    "monitoring",
    "claude-code",
    "telegram",
    "feishu",
    "ai-coding",
    "remote-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huanghuoguoguo/tlive"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.104",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "grammy": "^1.41.1",
    "https-proxy-agent": "^9.0.0",
    "markdown-it": "^14.1.1",
    "socks-proxy-agent": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.4",
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.4.0",
    "nodemon": "^3.1.14",
    "type-coverage": "^2.29.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
