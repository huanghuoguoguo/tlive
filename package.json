{
  "name": "tlive",
  "version": "0.2.8",
  "description": "Terminal live monitoring + IM bridge for AI coding tools",
  "type": "module",
  "bin": {
    "tlive": "./scripts/cli.js"
  },
  "files": [
    "scripts/cli.js",
    "scripts/postinstall.js",
    "scripts/preuninstall.js",
    "scripts/hook-handler.sh",
    "scripts/notify-handler.sh",
    "scripts/stop-handler.sh",
    "scripts/daemon.sh",
    "scripts/statusline.sh",
    "scripts/doctor.sh",
    "scripts/install.sh",
    "bridge/dist/",
    "bridge/package.json",
    "SKILL.md",
    "references/",
    "config.env.example"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "prepublishOnly": "cd bridge && npm install && npm run build && npm test",
    "build": "cd bridge && npm run build",
    "test": "cd bridge && npm test",
    "test:go": "cd core && go test ./... -v -timeout 30s"
  },
  "keywords": [
    "terminal",
    "monitoring",
    "claude-code",
    "telegram",
    "discord",
    "feishu",
    "ai-coding",
    "remote-terminal"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/y49/tlive"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/transformer-throttler": "^1.2.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
