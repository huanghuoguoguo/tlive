# TLive Configuration
# For Docker: copy to .env and fill in values
# For skill: /tlive setup creates ~/.termlive/config.env automatically

# Core
TL_PORT=8080
TL_TOKEN=your-token-here
TL_PUBLIC_URL=
# TL_CORE_URL=http://core:8080  # Only needed for Docker (auto-set in docker-compose)

# Global proxy for Telegram & Discord (optional)
# TL_PROXY=http://127.0.0.1:7890

# Enabled IM channels (comma-separated: telegram,discord,feishu)
TL_ENABLED_CHANNELS=

# Telegram
TL_TG_BOT_TOKEN=
TL_TG_CHAT_ID=
TL_TG_ALLOWED_USERS=

# Discord
TL_DC_BOT_TOKEN=
TL_DC_ALLOWED_USERS=
TL_DC_ALLOWED_CHANNELS=

# Feishu
TL_FS_APP_ID=
TL_FS_APP_SECRET=
TL_FS_ALLOWED_USERS=

# Runtime
TL_RUNTIME=claude
TL_DEFAULT_WORKDIR=
TL_DEFAULT_MODEL=
